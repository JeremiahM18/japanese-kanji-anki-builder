{
  "name": "japanese_kanji_builder",
  "version": "1.0.0",
  "description": "JLPT Kanji TSV exporter for building Anki decks",
  "type": "commonjs",
  "main": "src/server.js",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "nodemon",
    "start": "node src/server.js",
    "lint": "eslint src scripts test *.js",
    "test": "node test/run-tests.js",
    "bench:export": "node scripts/benchmarkExport.js",
    "corpus:normalize": "node scripts/normalizeSentenceCorpus.js",
    "corpus:report": "node scripts/reportSentenceCorpusCoverage.js",
    "corpus:init": "node scripts/initSentenceCorpus.js",
    "curated:normalize": "node scripts/normalizeCuratedStudyData.js",
    "curated:report": "node scripts/reportCuratedStudyCoverage.js",
    "curated:init": "node scripts/initCuratedStudyData.js",
    "build:artifacts": "node scripts/buildArtifacts.js",
    "media:report": "node scripts/reportMediaCoverage.js",
    "media:sync": "node scripts/syncMedia.js",
    "media:init": "node scripts/initMediaSources.js",
    "media:import:stroke-order": "node scripts/importFreeStrokeOrder.js",
    "doctor": "node scripts/doctor.js",
    "deck:preview": "node scripts/previewDeck.js",
    "deck:package": "node scripts/buildArtifacts.js",
    "deck:ready": "node scripts/prepareDeck.js",
    "deck:readiness": "node scripts/reportDeckReadiness.js",
    "media:plan": "node scripts/reportMediaPlan.js",
    "media:import:audio": "node scripts/importAudio.js",
    "media:sources": "node scripts/reportMediaSources.js",
    "media:plan:stroke-order": "node scripts/reportWikimediaStrokeOrderPlan.js",
    "media:discover:stroke-order": "node scripts/discoverWikimediaStrokeOrder.js",
    "media:fetch:stroke-order": "node scripts/fetchWikimediaStrokeOrder.js",
    "media:voicevox": "node scripts/generateVoicevoxAudio.js",
    "deck:review:n5": "node scripts/reviewGoldenLevel.js --level=5",
    "deck:apkg": "python scripts/buildApkg.py",
    "media:import:kanjivg": "node scripts/importKanjiVgStrokeOrder.js",
    "deck:review:n4": "node scripts/reviewGoldenLevel.js --level=4",
    "deck:readiness:global": "node scripts/reportDeckReadiness.js",
    "deck:words:ready": "node scripts/prepareWordDeck.js",
    "words:init": "node scripts/initWordStudyData.js",
    "deck:words:apkg": "python scripts/buildApkg.py --deck-kind=word --out-dir=out/word-build",
    "deck:words:review:n5": "node scripts/reviewGoldenWordLevel.js --level=5",
    "deck:words:reading-audit": "node scripts/reportWordReadingCoverage.js",
    "deck:words:reading-audit:n5": "node scripts/reportWordReadingCoverage.js --level=5"
  },
  "keywords": [
    "japanese",
    "kanji",
    "anki",
    "jlpt",
    "tsv"
  ],
  "author": "Jeremiah McDonald",
  "license": "ISC",
  "dependencies": {
    "express": "^5.2.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "eslint": "^10.0.2",
    "nodemon": "^3.1.14"
  }
}
