{
  "noteTypeName": "Japanese Kanji Builder",
  "cardTemplateName": "Recognition",
  "fieldNames": [
    "Kanji",
    "DisplayWord",
    "MeaningJP",
    "PrimaryReading",
    "OnReading",
    "KunReading",
    "StrokeOrder",
    "StrokeOrderImage",
    "StrokeOrderAnimation",
    "Audio",
    "Radical",
    "Notes",
    "ExampleSentence"
  ],
  "cssLines": [
    ".card {",
    "  font-family: \"Yu Gothic UI\", \"Hiragino Sans\", sans-serif;",
    "  font-size: 20px;",
    "  text-align: center;",
    "  color: #1f2933;",
    "  background: #f7f3ea;",
    "}",
    ".study-word {",
    "  font-size: 56px;",
    "  margin: 16px 0 8px;",
    "}",
    ".kanji-core {",
    "  font-size: 16px;",
    "  color: #52606d;",
    "  letter-spacing: 0.04em;",
    "}",
    ".reading-primary {",
    "  font-size: 28px;",
    "  font-weight: 700;",
    "}",
    ".reading-full {",
    "  font-size: 17px;",
    "  color: #52606d;",
    "}",
    ".reading, .meaning, .meta, .notes, .example, .media, .audio {",
    "  margin: 12px 0;",
    "  line-height: 1.5;",
    "}",
    ".media img {",
    "  max-width: 280px;",
    "  height: auto;",
    "}"
  ],
  "qfmt": "<div class=\"study-word\">{{DisplayWord}}</div>{{#PrimaryReading}}<div class=\"reading reading-primary\">{{PrimaryReading}}</div>{{/PrimaryReading}}<div class=\"kanji-core\">Core kanji: {{Kanji}}</div>",
  "afmtLines": [
    "{{FrontSide}}",
    "<hr id=\"answer\">",
    "<div class=\"meaning\">{{MeaningJP}}</div>",
    "{{#OnReading}}<div class=\"reading reading-full\">On-yomi: {{OnReading}}</div>{{/OnReading}}",
    "{{#KunReading}}<div class=\"reading reading-full\">Kun-yomi: {{KunReading}}</div>{{/KunReading}}",
    "<div class=\"media\">{{StrokeOrder}}</div>",
    "<div class=\"meta\">Radical: {{Radical}}</div>",
    "<div class=\"notes\">{{Notes}}</div>",
    "<div class=\"example\">{{ExampleSentence}}</div>",
    "<div class=\"audio\">{{Audio}}</div>"
  ]
}
