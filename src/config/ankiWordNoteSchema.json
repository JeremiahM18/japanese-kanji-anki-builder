{
  "noteTypeName": "Japanese Kanji Builder Word Note",
  "cardTemplateName": "Word Card",
  "fieldNames": [
    "Word",
    "Reading",
    "Meaning",
    "JLPTLevel",
    "KanjiBreakdown",
    "ExampleSentence",
    "Notes"
  ],
  "cssLines": [
    ".card {",
    "  font-family: \"Arial\", sans-serif;",
    "  text-align: center;",
    "  color: #1f2937;",
    "  background: #f8fafc;",
    "  padding: 20px 18px;",
    "}",
    ".word {",
    "  font-size: 42px;",
    "  font-weight: 700;",
    "  margin-bottom: 10px;",
    "}",
    ".word-reading {",
    "  font-size: 24px;",
    "  color: #334155;",
    "  margin-bottom: 8px;",
    "}",
    ".word-meaning {",
    "  font-size: 22px;",
    "  margin-bottom: 8px;",
    "}",
    ".word-level {",
    "  font-size: 16px;",
    "  color: #64748b;",
    "  margin-bottom: 18px;",
    "}",
    ".section {",
    "  text-align: left;",
    "  margin-top: 16px;",
    "}",
    ".section-title {",
    "  font-size: 15px;",
    "  font-weight: 700;",
    "  text-transform: uppercase;",
    "  letter-spacing: 0.04em;",
    "  color: #0f172a;",
    "  margin-bottom: 8px;",
    "}",
    ".kanji-breakdown-item {",
    "  border: 1px solid #cbd5e1;",
    "  border-radius: 12px;",
    "  padding: 12px;",
    "  margin-bottom: 10px;",
    "  background: #ffffff;",
    "}",
    ".kanji-breakdown-head {",
    "  display: flex;",
    "  justify-content: space-between;",
    "  align-items: baseline;",
    "  gap: 12px;",
    "  margin-bottom: 6px;",
    "}",
    ".kanji-char {",
    "  font-size: 30px;",
    "  font-weight: 700;",
    "}",
    ".kanji-primary {",
    "  font-size: 18px;",
    "  color: #475569;",
    "}",
    ".kanji-meaning {",
    "  margin-bottom: 6px;",
    "}",
    ".kanji-reading-line {",
    "  font-size: 15px;",
    "  color: #334155;",
    "  margin-bottom: 4px;",
    "}",
    ".kanji-media {",
    "  margin-top: 8px;",
    "}",
    ".kanji-media img {",
    "  max-width: 120px;",
    "  height: auto;",
    "  display: inline-block;",
    "  margin-right: 8px;",
    "}",
    ".notes, .example {",
    "  font-size: 16px;",
    "  line-height: 1.5;",
    "}"
  ],
  "qfmt": "<div class=\"word\">{{Word}}</div>",
  "afmtLines": [
    "{{FrontSide}}",
    "<hr id=\"answer\">",
    "{{#Reading}}<div class=\"word-reading\">{{Reading}}</div>{{/Reading}}",
    "{{#Meaning}}<div class=\"word-meaning\">{{Meaning}}</div>{{/Meaning}}",
    "{{#JLPTLevel}}<div class=\"word-level\">{{JLPTLevel}}</div>{{/JLPTLevel}}",
    "{{#KanjiBreakdown}}<div class=\"section\"><div class=\"section-title\">Kanji Breakdown</div>{{KanjiBreakdown}}</div>{{/KanjiBreakdown}}",
    "{{#ExampleSentence}}<div class=\"section\"><div class=\"section-title\">Example</div><div class=\"example\">{{ExampleSentence}}</div></div>{{/ExampleSentence}}",
    "{{#Notes}}<div class=\"section\"><div class=\"section-title\">Notes</div><div class=\"notes\">{{Notes}}</div></div>{{/Notes}}"
  ]
}
